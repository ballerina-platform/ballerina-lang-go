    int value = 499;
    int weight = 999;
};

function querySum0(Item0[] xs) returns int {
    int total = 0;
    int n = xs.length();
    foreach int k in 0 ..< n {
        Item0 v = xs[k];
        if v.value > 1 {
            total = (total + v.value + v.weight) % 1000000;
        }
    }
    return total;
}
