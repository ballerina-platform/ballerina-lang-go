function buildList() returns Step0[] {
    Step0[] xs = [];
    xs.push(namedStep0);
    xs.push(namedStep1);
    xs.push(namedStep2);
    xs.push(namedStep3);
    xs.push(namedStep4);
    xs.push(makeClosure0(7));
    xs.push(makeClosure1(11));
    xs.push(makeClosure2(13));
    return xs;
}

