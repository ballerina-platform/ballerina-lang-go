// @productions map-type-descriptor mapping-constructor-expr string-literal equality equality-expr relational-expr additive-expr assign-stmt local-var-decl-stmt int-literal
import ballerina/io;

public function main() {
    string s1 =
"";
    io:println(s1.length()); // @output 65556
    io:println(s1 == s1); // @output true
    io:println(s1 < s1); // @output false
    io:println("a" < s1); // @output true
    io:println("z" < s1); // @output false

    string s2 = s1 + "more";

    io:println(s2.length()); // @output 65560
    io:println(s2 == s2); // @output true
    io:println("a" < s2); // @output true
    io:println("z" < s2); // @output false

    io:println(s1 == s2); // @output false
    io:println(s1 < s2); // @output true
    io:println(s1 > s2); // @output false

    map<any> m = {};
    m[s1] = 42;
    m[s2] = 24;
    m["xyz"] = 17;
    io:println(m[s1]); // @output 42
}
