# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov
.cover/
.artifacts/

# Dependency directories
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env
*.DS_Store

# Binary generated by go build (root only; /bal avoids ignoring corpus/bal/)
/bal
/bal-debug

# Build outputs written by `bal run`/`bal pack` (mirrors Ballerina's target/ convention)
**/target/

# Generated test data files (run ./init.sh to regenerate)
corpus/**/*.json
parser/testdata/**/*.json
/corpus/parser/*
# Hand-authored bala fixture data (not generated)
!corpus/package-resolution/testdata/**/*.json

# IDE specific files
.idea/
/tree-gen

# Local Go caches (used by tooling like golangci-lint)
.gopath/
.gocache/
.gomodcache/
/.cache/

# Local lint tool binary
/bin/golangci-lint
