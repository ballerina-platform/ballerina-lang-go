# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov
.cover/
.artifacts/

# Dependency directories
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env
*.DS_Store

# Binary generated by go build (root only; /bal avoids ignoring corpus/bal/)
/bal
/bal-debug

# Generated test data files (run ./init.sh to regenerate).
# package.json and dependency-graph.json are bala-format metadata fixtures
# that must be tracked even though the broader corpus/**/*.json rule ignores
# generated parser outputs.
corpus/**/*.json
!corpus/**/package.json
!corpus/**/dependency-graph.json
parser/testdata/**/*.json
/corpus/parser/*

# IDE specific files
.idea/
/tree-gen

# Local Go caches (used by tooling like golangci-lint)
.gopath/
.gocache/
.gomodcache/
/.cache/

# Local lint tool binary
/bin/golangci-lint
